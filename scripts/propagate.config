# propagate.config — declarative mapping of templates → consumer repos
#
# Format (pipe-delimited, one row per template × target_repo):
#   template_name | target_repo | target_subpath | REPO_NAME | REPO_PATH | MAIN_BRANCH [| KEY=VALUE ...]
#
# Fields 1-6 are required. Fields 7+ are optional KEY=VALUE pairs that become
# @@KEY@@ substitution variables in the template.
#
# Rules:
#   - Lines starting with # are comments
#   - Blank lines ignored
#   - target_repo is a directory name under $HOME
#   - target_subpath is relative to the target repo root
#   - REPO_PATH should use $HOME/... (NOT /Users/...) — generated files run
#     on multiple nodes with different usernames (swetagurnani, jarvissand, etc.)
#   - Existing 6-field rows continue to work unchanged
#
# To add a new template: add rows here, run propagate_scripts.sh --dry-run
# To add a new consumer repo: add rows for each template the repo should receive
#
# Trait reference (per ADR-0005 + DEPLOYMENT.md §5.2):
#   F = Fan-out (multi-node SSH deploy)        — alpha, forge
#   B = Branch-safety (DEBT-027 + agent rules) — family, alpha, forge, council, print-copilot
#   P = PR-only (no commit script)             — financial, standards, data-sources
#   D = Submodule-consumed                     — data-sources

# ============================================================================
# check_sync.template.sh  →  scripts/check_sync.sh
# Pre-commit drift validator for B-trait repos (DEBT-027 enforcement)
# ============================================================================

# template|target_repo|target_subpath|REPO_NAME|REPO_PATH|MAIN_BRANCH
check_sync.template.sh|jarvis-family|scripts/check_sync.sh|jarvis-family|$HOME/jarvis-family|main
check_sync.template.sh|jarvis-alpha|scripts/check_sync.sh|jarvis-alpha|$HOME/jarvis-alpha|main
check_sync.template.sh|jarvis-forge|scripts/check_sync.sh|jarvis-forge|$HOME/jarvis-forge|main

# ============================================================================
# ruff_detect.template.sh  →  scripts/_lib/ruff_detect.sh
# Sourceable lib for resolving ruff binary path (venv first, then PATH)
# ============================================================================

# template|target_repo|target_subpath|REPO_NAME|REPO_PATH|MAIN_BRANCH
ruff_detect.template.sh|jarvis-family|scripts/_lib/ruff_detect.sh|jarvis-family|$HOME/jarvis-family|main
ruff_detect.template.sh|jarvis-alpha|scripts/_lib/ruff_detect.sh|jarvis-alpha|$HOME/jarvis-alpha|main
ruff_detect.template.sh|jarvis-forge|scripts/_lib/ruff_detect.sh|jarvis-forge|$HOME/jarvis-forge|main

# ============================================================================
# commit_core.template.sh  →  scripts/<repo>_commit.sh
# Unified commit script implementing ADR-0005 Q1+Q2+Q3 with F/B trait switches
#
# All trait switches (KEY=VALUE pairs):
#   COMMIT_SCRIPT_NAME       — name of generated script (used in self-references)
#   HAS_FANOUT               — true: F-trait, SSH fan-out to FANOUT_NODES
#   HAS_BRANCH_SAFETY        — true: B-trait, DEBT-027 + agent-must-branch rules
#   HAS_UI_BUILD             — true: run `npm run build` in ui/ before commit
#   HAS_SMOKE_CHECK          — true: run SMOKE_CHECK_CMD as pre-commit health check
#   HAS_AUTO_BRANCH          — true: on main from non-Air, auto-branch to feature/<date>-<slug>
#   FANOUT_NODES             — space-separated list (only used if HAS_FANOUT=true)
#   SMOKE_CHECK_CMD          — path to smoke check script, relative to repo root
#   MERGE_HELPER_SCRIPT_NAME — name of merge helper script (printed after auto-branch)
#
# Per DEPLOYMENT.md §5.2 adoption status:
#   - jarvis-family is the pilot (Session #10) — adopt now
#   - jarvis-alpha, jarvis-forge adopt in Sessions #11/#12 (rows below remain
#     SKIPPED until --initial flag is used, since their existing commit scripts
#     are hand-written without the GENERATED header)
# ============================================================================

# template|target_repo|target_subpath|REPO_NAME|REPO_PATH|MAIN_BRANCH|<extras>

# Family: B-trait pilot — full feature preservation (smoke + auto-branch + UI build)
commit_core.template.sh|jarvis-family|scripts/familyvault_commit.sh|jarvis-family|$HOME/jarvis-family|main|COMMIT_SCRIPT_NAME=familyvault_commit.sh|HAS_FANOUT=false|HAS_BRANCH_SAFETY=true|HAS_UI_BUILD=true|HAS_SMOKE_CHECK=true|HAS_AUTO_BRANCH=true|FANOUT_NODES=|SMOKE_CHECK_CMD=scripts/smoke_health.sh|MERGE_HELPER_SCRIPT_NAME=familyvault_merge_branch.sh

# Alpha: F+B-trait — pending Session #11 adoption (relies on post-deploy health curls, no pre-commit smoke)
commit_core.template.sh|jarvis-alpha|scripts/jarvisalpha_commit.sh|jarvis-alpha|$HOME/jarvis-alpha|main|COMMIT_SCRIPT_NAME=jarvisalpha_commit.sh|HAS_FANOUT=true|HAS_BRANCH_SAFETY=true|HAS_UI_BUILD=true|HAS_SMOKE_CHECK=false|HAS_AUTO_BRANCH=false|FANOUT_NODES=brain gateway endpoint sandbox|SMOKE_CHECK_CMD=|MERGE_HELPER_SCRIPT_NAME=

# Forge: F+B-trait single-target — pending Session #12 adoption
commit_core.template.sh|jarvis-forge|scripts/jarvisforge_commit.sh|jarvis-forge|$HOME/jarvis-forge|main|COMMIT_SCRIPT_NAME=jarvisforge_commit.sh|HAS_FANOUT=true|HAS_BRANCH_SAFETY=true|HAS_UI_BUILD=true|HAS_SMOKE_CHECK=false|HAS_AUTO_BRANCH=false|FANOUT_NODES=sandbox|SMOKE_CHECK_CMD=|MERGE_HELPER_SCRIPT_NAME=
